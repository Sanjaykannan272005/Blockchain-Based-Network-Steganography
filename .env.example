# ======================================================================
# STEALTH NETWORK - PRODUCTION ENVIRONMENT CONFIGURATION
# ======================================================================
# Instructions:
# 1. Copy this file to '.env'
# 2. Fill in the real values for your production deployment
# 3. DO NOT commit the .env file to version control (git)
# ======================================================================

# --- BLOCKCHAIN CONFIGURATION ---
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
CHAIN_ID=11155111
NETWORK_NAME=sepolia

# --- WALLET CONFIGURATION (ADMIN/OPERATOR) ---
# This address will be used for node registration and gas payments
OPERATOR_ADDRESS=0x000...
OPERATOR_PRIVATE_KEY=your_private_key_hex

# --- SMART CONTRACT ADDRESSES (SEPOLIA EXAMPLES) ---
REGISTRY_CONTRACT=0x1cc901Bd15355314BbAc729005e0a1b33A078DfE
ACCESS_CONTROL_CONTRACT=0x1fE68Aaa2562D60e666be91D43DA68736eA9c2B4
USER_REGISTRY_CONTRACT=0x100f386E79fCBce9fAC0a61a7264715BbB17b478
CONTROLLER_CONTRACT=0x2733432221F74025c5657CE76E8E2E55e92f47cb
DEAD_DROP_CONTRACT=0xAe39AC41FdF56F26bf051026878b8fb70C61341f

# --- SYSTEM SETTINGS ---
LOG_LEVEL=INFO
DEBUG=False
SECRET_KEY=generate_a_random_string_for_flask_sessions
